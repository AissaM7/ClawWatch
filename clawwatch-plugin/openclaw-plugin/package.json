  "keywords": [
    "openclaw",
    "observability",
    "clawwatch",
    "agent",
    "monitoring"
  ],
  "license": "MIT",
  "author": "ClawWatch Contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/clawwatch/openclaw-plugin"
  },
  "engines": {
    "node": ">=18"
  },
  "openclaw": {
    "pluginId": "clawwatch",
    "displayName": "ClawWatch",
